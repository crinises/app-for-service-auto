<Window x:Class="ServiceAuto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Service Auto"
        Height="720" Width="1100"
        MinHeight="580" MinWidth="860"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Br_BgDeep}"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="5"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource Br_Border}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Br_BgSide}" CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Ellipse Width="9" Height="9" Fill="{StaticResource Br_Accent}" Margin="0,0,8,0" Opacity="0.9"/>
                        <TextBlock Text="Service Auto" Foreground="{StaticResource Br_TxtPri}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="  |  Gestiune atelier" Foreground="{StaticResource Br_TxtMut}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="─" Style="{StaticResource Btn_WinCtrl}" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="□" Style="{StaticResource Btn_WinCtrl}" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Style="{StaticResource Btn_WinClose}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource Br_BgSide}"
                        BorderBrush="{StaticResource Br_Border}" BorderThickness="0,1,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="MENIU" Foreground="{StaticResource Br_TxtMut}"
                                   FontSize="9.5" FontWeight="SemiBold" Margin="22,18,0,8"/>

                        <StackPanel Grid.Row="1" Margin="0,2,0,0">
                            <Button x:Name="BtnNavClienti" Style="{StaticResource Btn_NavActive}" Click="NavClienti_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F464;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clienti" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnNavAuto" Style="{StaticResource Btn_Nav}" Click="NavAuto_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F697;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Automobile" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnNavProg" Style="{StaticResource Btn_Nav}" Click="NavProg_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C5;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Programari" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="12,0,12,14" Padding="12,10"
                                Background="{StaticResource Br_BgCard}"
                                CornerRadius="8" BorderBrush="{StaticResource Br_Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TxtDbStatus" Text="● Conectat" FontSize="11"
                                           Foreground="{StaticResource Br_Success}"/>
                                <TextBlock Text="service_auto @ localhost" FontSize="10"
                                           Foreground="{StaticResource Br_TxtMut}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- MAIN AREA -->
                <Border Grid.Column="1" Background="{StaticResource Br_BgMain}"
                        BorderBrush="{StaticResource Br_Border}" BorderThickness="0,1,0,0">
                    <Grid>

                        <!-- PAGE CLIENTI -->
                        <Grid x:Name="PageClienti" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Clienti" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gestionarea inregistrarilor de clienti"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="18,16">
                                <WrapPanel>
                                    <StackPanel Width="190" Margin="0,0,14,10">
                                        <TextBlock Text="NUME" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtNume"/>
                                        <TextBlock x:Name="ErrNume" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="190" Margin="0,0,14,10">
                                        <TextBlock Text="PRENUME" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtPrenume"/>
                                        <TextBlock x:Name="ErrPrenume" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="190" Margin="0,0,14,10">
                                        <TextBlock Text="TELEFON" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtTelefon"/>
                                        <TextBlock x:Name="ErrTelefon" Style="{StaticResource ErrLabel}" Text="Doar cifre, minim 7"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,18,0,0">
                                        <Button Content="Adauga" Style="{StaticResource Btn_Primary}"
                                                Margin="0,0,8,0" Width="100" Click="BtnAdaugaClient_Click"/>
                                        <Button Content="Modifica" Style="{StaticResource Btn}"
                                                Margin="0,0,8,0" Width="100" Click="BtnModificaClient_Click"/>
                                        <Button Content="Sterge" Style="{StaticResource Btn_Danger}"
                                                Width="90" Click="BtnStergeClient_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,10" Padding="14,10"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Cauta dupa nume:" Foreground="{StaticResource Br_TxtSec}"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox x:Name="TxtSearchClient" Width="260" Height="32"
                                             TextChanged="TxtSearchClient_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgClienti" SelectionChanged="DgClienti_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"      Binding="{Binding ClientID}"  Width="60"/>
                                        <DataGridTextColumn Header="Nume"    Binding="{Binding Nume}"      Width="*"/>
                                        <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}"   Width="*"/>
                                        <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}"   Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- PAGE AUTOMOBILE -->
                        <Grid x:Name="PageAuto" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Automobile" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gestionarea parcului auto al clientilor"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="18,16">
                                <WrapPanel>
                                    <StackPanel Width="230" Margin="0,0,14,10">
                                        <TextBlock Text="CLIENT" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="CmbClientAuto"/>
                                        <TextBlock x:Name="ErrClientAuto" Style="{StaticResource ErrLabel}" Text="Selectati un client"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="0,0,14,10">
                                        <TextBlock Text="MARCA" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtMarca"/>
                                        <TextBlock x:Name="ErrMarca" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="0,0,14,10">
                                        <TextBlock Text="MODEL" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtModel"/>
                                        <TextBlock x:Name="ErrModel" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="0,0,14,10">
                                        <TextBlock Text="NR. INMATRICULARE" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtNrInmatriculare"/>
                                        <TextBlock x:Name="ErrNr" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,18,0,0">
                                        <Button Content="Adauga" Style="{StaticResource Btn_Primary}"
                                                Margin="0,0,8,0" Width="100" Click="BtnAdaugaAuto_Click"/>
                                        <Button Content="Modifica" Style="{StaticResource Btn}"
                                                Margin="0,0,8,0" Width="100" Click="BtnModificaAuto_Click"/>
                                        <Button Content="Sterge" Style="{StaticResource Btn_Danger}"
                                                Width="90" Click="BtnStergeAuto_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgAuto" SelectionChanged="DgAuto_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"     Binding="{Binding AutomobilID}"        Width="60"/>
                                        <DataGridTextColumn Header="Client" Binding="{Binding Client}"             Width="*"/>
                                        <DataGridTextColumn Header="Marca"  Binding="{Binding Marca}"              Width="120"/>
                                        <DataGridTextColumn Header="Model"  Binding="{Binding Model}"              Width="120"/>
                                        <DataGridTextColumn Header="Nr. Inmatriculare" Binding="{Binding NumarInmatriculare}" Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- PAGE PROGRAMARI -->
                        <Grid x:Name="PageProg" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Programari" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gestionarea programarilor la service"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="18,16">
                                <WrapPanel>
                                    <StackPanel Width="260" Margin="0,0,14,10">
                                        <TextBlock Text="AUTOMOBIL" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="CmbAutoProg"/>
                                        <TextBlock x:Name="ErrAutoProg" Style="{StaticResource ErrLabel}" Text="Selectati un automobil"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="0,0,14,10">
                                        <TextBlock Text="DATA PROGRAMARII" Style="{StaticResource FormLabel}"/>
                                        <DatePicker x:Name="DtpProgramare" SelectedDateFormat="Short"/>
                                        <TextBlock x:Name="ErrData" Style="{StaticResource ErrLabel}" Text="Data nu poate fi in trecut"/>
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="0,0,14,10">
                                        <TextBlock Text="TIP SERVICIU" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtTipServiciu"/>
                                        <TextBlock x:Name="ErrTip" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="0,0,14,10">
                                        <TextBlock Text="STATUS" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="CmbStatusProg">
                                            <ComboBoxItem Content="Programat" IsSelected="True"/>
                                            <ComboBoxItem Content="In lucru"/>
                                            <ComboBoxItem Content="Finalizat"/>
                                            <ComboBoxItem Content="Anulat"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,18,0,0">
                                        <Button Content="Adauga" Style="{StaticResource Btn_Primary}"
                                                Margin="0,0,8,0" Width="100" Click="BtnAdaugaProg_Click"/>
                                        <Button Content="Modifica" Style="{StaticResource Btn}"
                                                Margin="0,0,8,0" Width="100" Click="BtnModificaProg_Click"/>
                                        <Button Content="Sterge" Style="{StaticResource Btn_Danger}"
                                                Width="90" Click="BtnStergeProg_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,10" Padding="14,10"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Filtrare dupa status:" Foreground="{StaticResource Br_TxtSec}"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ComboBox x:Name="CmbFilterStatus" Width="200" Height="32"
                                              SelectionChanged="CmbFilterStatus_Changed">
                                        <ComboBoxItem Content="Toate" IsSelected="True"/>
                                        <ComboBoxItem Content="Programat"/>
                                        <ComboBoxItem Content="In lucru"/>
                                        <ComboBoxItem Content="Finalizat"/>
                                        <ComboBoxItem Content="Anulat"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgProg" SelectionChanged="DgProg_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"         Binding="{Binding ProgramareID}"  Width="60"/>
                                        <DataGridTextColumn Header="Automobil"  Binding="{Binding Automobil}"     Width="2*"/>
                                        <DataGridTextColumn Header="Data"       Binding="{Binding DataProgramarii, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                                        <DataGridTextColumn Header="Tip"        Binding="{Binding TipServiciu}"   Width="*"/>
                                        <DataGridTemplateColumn Header="Status" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border HorizontalAlignment="Left" CornerRadius="5" Padding="9,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource Br_NavSel}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StatusProgramare}" Value="In lucru">
                                                                        <Setter Property="Background" Value="{StaticResource Br_WarnBg}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StatusProgramare}" Value="Finalizat">
                                                                        <Setter Property="Background" Value="{StaticResource Br_SuccessBg}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StatusProgramare}" Value="Anulat">
                                                                        <Setter Property="Background" Value="{StaticResource Br_DangerBg}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding StatusProgramare}" FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Br_AccentHov}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding StatusProgramare}" Value="In lucru">
                                                                            <Setter Property="Foreground" Value="{StaticResource Br_Warning}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusProgramare}" Value="Finalizat">
                                                                            <Setter Property="Foreground" Value="{StaticResource Br_Success}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusProgramare}" Value="Anulat">
                                                                            <Setter Property="Foreground" Value="{StaticResource Br_Danger}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
